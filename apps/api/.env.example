# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://itdesk_user:changeme@localhost:27017/itdesk

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256) — generate with: node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048});console.log(privateKey.export({type:'pkcs8',format:'pem'}));console.log(publicKey.export({type:'spki',format:'pem'}))"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# LDAP / Active Directory
LDAP_ENABLED=false
LDAP_URL=ldap://your-dc.domain.local
LDAP_BIND_DN=CN=svc-itdesk,OU=Service Accounts,DC=domain,DC=local
LDAP_BIND_CREDENTIALS=changeme
LDAP_SEARCH_BASE=DC=domain,DC=local
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
LDAP_GROUP_BASE=OU=Groups,DC=domain,DC=local
LDAP_ADMIN_GROUP=CN=IT-Admins,OU=Groups,DC=domain,DC=local
LDAP_TECH_GROUP=CN=IT-Technicians,OU=Groups,DC=domain,DC=local
LDAP_USER_GROUP=CN=All-Users,OU=Groups,DC=domain,DC=local

# Email (optional for Phase 1)
SMTP_ENABLED=false
SMTP_HOST=smtp.domain.local
SMTP_PORT=587
SMTP_USER=itdesk@domain.local
SMTP_PASS=changeme
SMTP_FROM="IT Helpdesk <itdesk@domain.local>"

# Microsoft Intune (Azure AD)
INTUNE_ENABLED=false
INTUNE_TENANT_ID=
INTUNE_CLIENT_ID=
INTUNE_CLIENT_SECRET=
INTUNE_SYNC_SCHEDULE=0 * * * *

# Cisco Meraki
MERAKI_ENABLED=false
MERAKI_API_KEY=
MERAKI_ORG_ID=
MERAKI_SYNC_SCHEDULE=0 * * * *

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25
